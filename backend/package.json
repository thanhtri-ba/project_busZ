    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.12.7",
    "prisma": "^5.12.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
