{
  "name": "busz-backend",
  "version": "1.0.0",
  "description": "Backend for BusZ app using Node.js, Express, and Prisma.",
  "main": "src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
